{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AFK Engineer",
  "version": "1.0.0",
  "identifier": "com.afkengineer.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AFK Engineer",
        "width": 1180,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "theme": "Dark",
        "backgroundColor": "#0f1216"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/shinguakira/afk-game/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzM0Y3NzIyRjJFQkNDQTkKUldTcHpPdnlJbmMvbzV1UUJPcjhBU3RLdnNBeXlwc2pRZUNRZmpkR0ZmSWc4bHk0VHdlVkdlclMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
