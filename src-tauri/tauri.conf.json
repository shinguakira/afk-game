{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Idle Engineer",
  "version": "0.1.0",
  "identifier": "com.idleengineer.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Idle Engineer",
        "width": 1180,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
