{
  "name": "afk-game",
  "version": "0.1.0",
  "private": true,
  "description": "Melvor-Idle-style AFK/idle RPG. Vite+React client, tiny Express+TS save server (no DB).",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w client run build",
    "test": "npm -w client run test",
    "start": "npm -w server run start",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "lint": "oxlint client/src client/test server/src",
    "format": "oxfmt client/src client/test server/src",
    "format:check": "oxfmt --check client/src client/test server/src",
    "knip": "knip"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "concurrently": "^9.1.2",
    "knip": "^6.17.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0"
  }
}
